# backend/.env 예시 — 이 파일을 복사해 backend/.env 로 만들고 값을 채우세요.
# (실제 .env 는 .gitignore 로 커밋에서 제외됩니다)

# Gemini API 키 (상품 번역/카피 생성에 사용)
GEMINI_API_KEY=your_gemini_api_key_here

# 백엔드 외부 접근 URL (정적 이미지/누끼 경로 생성에 사용)
BACKEND_URL=http://localhost:8002

# 결제 개발 모드: true 면 실제 PG 검증 없이 결제 성공 처리(로컬 데모). 운영에서는 false 필수.
PAYMENTS_DEV_MODE=true

# CORS 허용 오리진 (쉼표 구분)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# (선택) DB URL — 기본값은 프로젝트 루트 SQLite(sql_app.db)
# DATABASE_URL=sqlite:///./sql_app.db
# MySQL 전환 시 아래 예시를 주석 해제하고 세팅하세요:
# DATABASE_URL=mysql+pymysql://유저명:비밀번호@localhost:3306/DB명?charset=utf8mb4

# ── 아래 항목은 OS 환경변수로 설정해야 적용됩니다(uvicorn --env-file 미사용 시) ──
# JWT_SECRET_KEY=change_me_in_production
# SEED_ADMIN_PASSWORD=admin1234
# PORTONE_API_KEY=
# PORTONE_API_SECRET=

# ── 이메일 발송 설정 (Daum 스마트워크 SMTP 기준) ──
SMTP_HOST=smtp.daum.net
SMTP_PORT=465
SMTP_USERNAME=your_daum_id@luxai.co.kr
SMTP_PASSWORD=your_daum_password_or_app_password
EMAIL_FROM=your_daum_id@luxai.co.kr
EMAIL_FROM_NAME="LUXAI 쇼핑몰"
